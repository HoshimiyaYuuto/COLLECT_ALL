<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="program.intro_to_cs_lab_final_project.Controller">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="scoreLabel" alignment="BOTTOM_CENTER" contentDisplay="CENTER" text="SCORE: 00000">
                    <font>
                        <Font name="Courier New" size="20.0" />
                    </font>
                    <HBox.margin>
                        <Insets left="20.0" />
                    </HBox.margin>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <ImageView fx:id="clockImage" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true" />
                <Label fx:id="clockLabel" text="00:00">
                    <font>
                        <Font name="Courier New" size="20.0" />
                    </font>
                    <HBox.margin>
                        <Insets left="10.0" right="20.0" />
                    </HBox.margin>
                </Label>
                <ImageView fx:id="selectImage" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true" />
            </children>
        </HBox>
    </top>

    <center>
        <GridPane fx:id="mapGrid" alignment="CENTER" BorderPane.alignment="CENTER">
        </GridPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="40.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <children>
                <Label text="[WASD]: 移動 | [Space]: 攻擊/破冰" textFill="#666666">
                    <font>
                        <Font name="Courier New" size="14.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </bottom>
   <left>
      <StackPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: rgba(0, 0, 0, 0.5);" visible="false" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0" visible="false">
               <children>
                  <Label alignment="CENTER" text="VICTORY!" textFill="GOLD">
                     <font>
                        <Font name="Eras Bold ITC" size="75.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" text="You collected all!" textFill="WHITE">
                     <font>
                        <Font name="Berlin Sans FB Demi Bold" size="25.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                     <children>
                        <Button mnemonicParsing="false" prefHeight="50.0" prefWidth="150.0" text="Replay">
                           <font>
                              <Font name="Berlin Sans FB Demi Bold" size="30.0" />
                           </font>
                        </Button>
                        <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="150.0" text="Menu">
                           <font>
                              <Font name="Berlin Sans FB Demi Bold" size="30.0" />
                           </font>
                        </Button>
                     </children>
                     <padding>
                        <Insets top="50.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
            <VBox alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="200.0" prefWidth="100.0" spacing="10.0" visible="false">
               <children>
                  <Label alignment="CENTER" text="GAME OVER" textFill="#fb3030">
                     <font>
                        <Font name="Eras Bold ITC" size="75.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" text="Failure :(" textFill="WHITE">
                     <font>
                        <Font name="Berlin Sans FB Demi Bold" size="25.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                     <children>
                        <Button mnemonicParsing="false" prefHeight="50.0" prefWidth="150.0" text="Retry">
                           <font>
                              <Font name="Berlin Sans FB Demi Bold" size="30.0" />
                           </font>
                        </Button>
                        <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="150.0" text="Menu">
                           <font>
                              <Font name="Berlin Sans FB Demi Bold" size="30.0" />
                           </font>
                        </Button>
                     </children>
                     <padding>
                        <Insets top="50.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </left>
</BorderPane>
