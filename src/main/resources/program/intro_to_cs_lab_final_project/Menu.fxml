<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="program.intro_to_cs_lab_final_project.Controller">
   <children>
      <ImageView fitHeight="600.0" fitWidth="600.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Background/StonyWall.jpg" />
         </image>
      </ImageView>
      <VBox fx:id="MainMenu" alignment="CENTER" prefHeight="600.0" prefWidth="600.0" spacing="40.0" style="-fx-background-color: transparent;">
         <children>
            <VBox alignment="CENTER" layoutX="30.0" layoutY="325.0" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <Label alignment="CENTER" text="COLLECT" textFill="#ecf0f1">
                     <font>
                        <Font name="Berlin Sans FB Demi Bold" size="85.0" />
                     </font>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                     <effect>
                        <DropShadow blurType="TWO_PASS_BOX" spread="1.0" />
                     </effect>
                  </Label>
                  <Label alignment="CENTER" text="ALL" textFill="#ecf0f1">
                     <font>
                        <Font name="Berlin Sans FB Demi Bold" size="85.0" />
                     </font>
                     <effect>
                        <DropShadow blurType="TWO_PASS_BOX" spread="1.0" />
                     </effect>
                  </Label>
                  <Label text="- PLAIN EDITION -" textFill="#ff5040">
                     <font>
                        <Font name="Courier New Bold" size="20.0" />
                     </font>
                     <padding>
                        <Insets top="10.0" />
                     </padding>
                  </Label>
               </children>
            </VBox>
            <HBox alignment="CENTER" spacing="50.0">
               <children>
                  <Button fx:id="StartGame" mnemonicParsing="false" onAction="#handleStartGame" prefHeight="45.0" prefWidth="120.0" text="Start">
                     <font>
                        <Font name="Berlin Sans FB Demi Bold" size="30.0" />
                     </font>
                  </Button>
                  <Button fx:id="ExitGame" mnemonicParsing="false" onAction="#handleExitGame" prefHeight="45.0" prefWidth="120.0" text="Exit">
                     <font>
                        <Font name="Berlin Sans FB Demi Bold" size="30.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
      <VBox fx:id="SelectHero" alignment="CENTER" prefHeight="600.0" prefWidth="600.0" spacing="40.0" style="-fx-background-color: transparent;" visible="false">
      
          <children>
            <Label alignment="TOP_CENTER" text="COLLECT ALL" textFill="#ecf0f1">
               <font>
                  <Font name="Berlin Sans FB Demi Bold" size="60.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
               <effect>
                  <DropShadow blurType="TWO_PASS_BOX" spread="1.0" />
               </effect>
            </Label>
      
              <Label text="- CHOOSE YOUR HERO TO START GAME -" textFill="#a8fb8a">
                  <font>
                      <Font name="Berlin Sans FB Demi Bold" size="18.0" />
                  </font>
               <VBox.margin>
                  <Insets bottom="-10.0" top="-10.0" />
               </VBox.margin>
              </Label>
            <VBox prefHeight="200.0" prefWidth="100.0" spacing="30.0">
               <children>
            
                    <VBox alignment="CENTER" spacing="10.0">
                        <children>
                        <HBox alignment="CENTER" layoutX="10.0" layoutY="10.0" spacing="50.0">
                           <children>
                              <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@Character/Bald/Faceset.png" />
                                 </image>
                              </ImageView>
                              <ImageView fitHeight="100.0" fitWidth="100.0" layoutX="190.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@Character/Flameman/Faceset.png" />
                                 </image>
                              </ImageView>
                              <ImageView fitHeight="100.0" fitWidth="100.0" layoutX="300.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@Character/Frozenman/Faceset.png" />
                                 </image>
                              </ImageView>
                           </children>
                        </HBox>
                            <HBox alignment="CENTER" spacing="30.0">
                                <children>
                                    <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Bald">
                                        <font>
                                    <Font name="Berlin Sans FB Demi Bold" size="16.0" />
                                 </font>
                                    </Button>
                                    <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Flameman">
                                        <font>
                                    <Font name="Berlin Sans FB Demi Bold" size="16.0" />
                                 </font>
                                    </Button>
                                    <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Frozenman">
                                        <font>
                                    <Font name="Berlin Sans FB Demi Bold" size="16.0" />
                                 </font>
                                    </Button>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                  <VBox alignment="CENTER" layoutX="10.0" layoutY="10.0" spacing="10.0">
                     <children>
                        <HBox alignment="CENTER" layoutX="10.0" layoutY="10.0" spacing="50.0">
                           <children>
                              <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@Character/Mage/Faceset.png" />
                                 </image>
                              </ImageView>
                              <ImageView fitHeight="100.0" fitWidth="100.0" layoutX="190.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@Character/Robot/Faceset.png" />
                                 </image>
                              </ImageView>
                              <ImageView fitHeight="100.0" fitWidth="100.0" layoutX="300.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@Character/Samurai/Faceset.png" />
                                 </image>
                              </ImageView>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="30.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Mage">
                                 <font>
                                    <Font name="Berlin Sans FB Demi Bold" size="16.0" />
                                 </font>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Robot">
                                 <font>
                                    <Font name="Berlin Sans FB Demi Bold" size="16.0" />
                                 </font>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Samurai">
                                 <font>
                                    <Font name="Berlin Sans FB Demi Bold" size="16.0" />
                                 </font>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
          </children>
      
          <padding>
              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
          </padding>
      </VBox>
   </children>
</StackPane>
