<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="program.intro_to_cs_lab_final_project.Controller">
   <children>
      <VBox id="MainMenu" alignment="CENTER" prefHeight="600.0" prefWidth="600.0" spacing="40.0" style="-fx-background-color: #2c3e50;">
         <children>
            <Label alignment="CENTER" text="COLLECT ALL" textFill="#ecf0f1">
               <font>
                  <Font name="Courier New Bold" size="38.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="30.0">
               <children>
                  <Button id="StartGame" mnemonicParsing="false" onAction="#handleStartGame" prefHeight="45.0" prefWidth="120.0" text="Start">
                     <font>
                        <Font name="Courier New Bold" size="14.0" />
                     </font>
                  </Button>
                  <Button id="ExitGame" layoutX="10.0" layoutY="33.0" mnemonicParsing="false" onAction="#handleExitGame" prefHeight="45.0" prefWidth="120.0" text="Exit">
                     <font>
                        <Font name="Courier New Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
      <VBox id="SelectHero" alignment="CENTER" prefHeight="600.0" prefWidth="600.0" spacing="40.0" style="-fx-background-color: #2c3e50;" visible="false">
      
          <children>
              <Label text="COLLECT ALL" textFill="#ecf0f1">
                  <font>
                      <Font name="Courier New Bold" size="38.0" />
                  </font>
              </Label>
      
              <Label text="- PLAIN EDITION -" textFill="#e74c3c">
                  <font>
                      <Font name="Courier New Bold" size="20.0" />
                  </font>
                  <VBox.margin>
                      <Insets top="-30.0" />
                  </VBox.margin>
              </Label>
      
              <Label text="CHOOSE YOUR HERO" textFill="#bdc3c7">
                  <font>
                      <Font name="Courier New" size="16.0" />
                  </font>
              </Label>
      
              <VBox alignment="CENTER" spacing="15.0">
                  <children>
                      <HBox alignment="CENTER" spacing="20.0">
                          <children>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Bald">
                                  <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Flameman">
                                  <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Frozenman">
                                  <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                              </Button>
                          </children>
                      </HBox>
      
                      <HBox alignment="CENTER" spacing="20.0">
                          <children>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Mage">
                                  <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Robot">
                                  <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Samurai">
                                  <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                              </Button>
                          </children>
                      </HBox>
                  <HBox alignment="CENTER" layoutX="10.0" layoutY="10.0" spacing="20.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Bald">
                           <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Flameman">
                           <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleCharacterSelect" prefHeight="45.0" prefWidth="120.0" text="Frozenman">
                           <font>
                              <Font name="Courier New Bold" size="14.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
                  </children>
              </VBox>
      
              <Label text="Press Button to Start Game" textFill="#7f8c8d">
                  <font>
                      <Font name="Courier New" size="12.0" />
                  </font>
              </Label>
          </children>
      
          <padding>
              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
          </padding>
      </VBox>
   </children>
</StackPane>
